{
  "name": "hermes-gateway",
  "version": "0.0.2",
  "type": "module",
  "description": "ACP multi-channel gateway (Telegram via Chat SDK, Discord-ready V2)",
  "keywords": [
    "acp",
    "agent",
    "telegram",
    "chat-sdk",
    "cli"
  ],
  "bin": {
    "hermes": "dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "release:check": "npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RayZhao1998/Hermes.git"
  },
  "homepage": "https://github.com/RayZhao1998/Hermes#readme",
  "bugs": {
    "url": "https://github.com/RayZhao1998/Hermes/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@chat-adapter/state-memory": "^4.17.0",
    "@chat-adapter/telegram": "^4.17.0",
    "@clack/prompts": "^1.1.0",
    "chat": "^4.17.0",
    "dotenv": "^17.3.1",
    "pino": "^10.3.1",
    "undici": "^7.22.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
